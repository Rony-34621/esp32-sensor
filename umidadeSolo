</html>

)rawliteral";

  html.replace("%NIVEL%", String(nivelMinimo));

  return html;
}

// ======================================================
// FUNCOES HTTP TASMOTA
// ======================================================
void ligarBombaTasmota() {

  if (WiFi.status() != WL_CONNECTED)
    return;

  HTTPClient http;

  http.begin(tasmotaOn);

  int httpCode = http.GET();

  Serial.print("Ligando bomba - HTTP Code: ");
  Serial.println(httpCode);

  http.end();
}

void desligarBombaTasmota() {

  if (WiFi.status() != WL_CONNECTED)
    return;

  HTTPClient http;

  http.begin(tasmotaOff);

  int httpCode = http.GET();

  Serial.print("Desligando bomba - HTTP Code: ");
  Serial.println(httpCode);

  http.end();
}

// ======================================================
// ROTAS WEB
// ======================================================
void handleRoot() {
  server.send(200, "text/html", gerarPagina());
}

void handleData() {

  String json = "{";

  json += "\"umidade\":" + String(umidade) + ",";
  json += "\"bomba\":" + String(bombaLigada ? "true" : "false") + ",";
  json += "\"manual\":" + String(modoManual ? "true" : "false");

  json += "}";

  server.send(200, "application/json", json);
}

void handleSetNivel() {

  if (server.hasArg("valor")) {

    nivelMinimo = server.arg("valor").toInt();

    Serial.print("Nivel minimo ajustado para: ");
    Serial.println(nivelMinimo);
  }

  server.send(200, "text/plain", "OK");
}

void handleManual() {

  modoManual = !modoManual;

  Serial.print("Modo manual: ");

  Serial.println(
    modoManual ?
    "Ativado" :
    "Desativado"
  );

  server.send(200, "text/plain", "OK");
}

void handleToggle() {

  bombaLigada = !bombaLigada;

  if (bombaLigada) {
    ligarBombaTasmota();
  }
  else {
    desligarBombaTasmota();
  }

  Serial.println(
    bombaLigada ?
    "Bomba LIGADA (manual)" :
    "Bomba DESLIGADA (manual)"
  );

  server.send(200, "text/plain", "OK");
}

// ======================================================
// SETUP
// ======================================================
void setup() {

  Serial.begin(115200);

  WiFi.begin(ssid, password);

  Serial.print("Conectando ao WiFi");

  while (WiFi.status() != WL_CONNECTED) {

    delay(500);
    Serial.print(".");
    
    if 

  }

  Serial.println("");
  Serial.println("WiFi conectado!");

  Serial.print("IP do ESP32: ");
  Serial.println(WiFi.localIP());

  // ==========================================
  // ROTAS
  // ==========================================
  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/setnivel", handleSetNivel);
  server.on("/manual", handleManual);
  server.on("/toggle", handleToggle);

  server.begin();

  Serial.println("Servidor web iniciado");
}

// ======================================================
// LOOP PRINCIPAL
// ======================================================
void loop() {

  server.handleClient();

  // ==========================================
  // LEITURA DO SENSOR
  // ==========================================
  if (millis() - ultimaLeitura > intervaloLeitura) {

    // ==========================================
    // LEITURA ANALOGICA DO SENSOR
    // ==========================================
    //
    // IMPORTANTE:
    // Ajuste os valores conforme seu sensor
    //
    // Solo seco     -> valor alto
    // Solo molhado  -> valor baixo
    //
    // Valores iniciais de exemplo:
    //
    // seco:      3200
    // molhado:   1400
    //
    // ==========================================

    int leituraBruta = analogRead(SENSOR_PIN);

    // ==========================================
    // CALIBRACAO
    // ==========================================
    int valorSeco = 3200;
    int valorMolhado = 1400;

    // ==========================================
    // CONVERTE PARA %
    // ==========================================
    umidade = map(
      leituraBruta,
      valorSeco,
      valorMolhado,
      0,
      100
    );

    // LIMITA ENTRE 0 E 100
    umidade = constrain(umidade, 0, 100);

    ultimaLeitura = millis();

    // ==========================================
    // DEBUG SERIAL
    // ==========================================
    // Pode comentar esse trecho futuramente
    // ==========================================

    Serial.println("========== SENSOR ==========");

    Serial.print("Leitura ADC: ");
    Serial.println(leituraBruta);

    Serial.print("Umidade calculada: ");
    Serial.print(umidade);
    Serial.println("%");

    Serial.println("============================");
  }

  // ==================================================
  // CONTROLE AUTOMATICO
  // ==================================================
  if (!modoManual) {

    // ==========================================
    // LIGA ABAIXO DO MINIMO
    // ==========================================
    if (umidade < nivelMinimo && !bombaLigada) {

      ligarBombaTasmota();

      bombaLigada = true;

      Serial.println("Bomba LIGADA (automatico)");
    }

    // ==========================================
    // DESLIGA EM 80%
    // ==========================================
    if (umidade >= 80 && bombaLigada) {

      desligarBombaTasmota();

      bombaLigada = false;

      Serial.println("Bomba DESLIGADA (automatico)");
    }
  }
}

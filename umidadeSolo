// ======================================================
// WIFI
// ======================================================
bool conectarWiFi(
  const char* ssid,
  const char* senha,
  int timeoutMs
) {

  WiFi.begin(ssid, senha);

  Serial.print("Conectando em ");
  Serial.println(ssid);

  unsigned long inicio = millis();

  while (
    WiFi.status() != WL_CONNECTED &&
    millis() - inicio < timeoutMs
  ) {

    delay(500);
    Serial.print(".");
  }

  if (WiFi.status() == WL_CONNECTED) {

    Serial.println("");
    Serial.println("WiFi conectado!");

    Serial.print("IP: ");
    Serial.println(WiFi.localIP());

    return true;
  }

  Serial.println("");
  Serial.println("Falha na conexao");

  WiFi.disconnect(true);

  return false;
}

void conectarWiFiMulti() {

  bool conectado = false;

  conectado = conectarWiFi(
    WIFI_1_SSID,
    WIFI_1_PASS,
    10000
  );

  if (!conectado) {

    Serial.println(
      "Tentando segunda rede..."
    );

    conectado = conectarWiFi(
      WIFI_2_SSID,
      WIFI_2_PASS,
      10000
    );
  }

  if (!conectado) {

    Serial.println(
      "Nenhuma rede conectou"
    );
  }
}

// ======================================================
// NTP
// ======================================================
void sincronizarHorario() {

  configTime(
    GMT_OFFSET,
    DAYLIGHT_OFFSET,
    NTP_SERVER
  );

  struct tm timeinfo;

  if (!getLocalTime(&timeinfo)) {

    Serial.println(
      "Falha ao sincronizar horario"
    );

    return;
  }

  Serial.println(
    "Horario sincronizado!"
  );
}

// ======================================================
// ENVIO API
// ======================================================
void enviarDadosAPI() {

  if (WiFi.status() != WL_CONNECTED) {

    conectarWiFiMulti();

    if (WiFi.status() != WL_CONNECTED) {
      return;
    }
  }

  struct tm timeinfo;

  if (!getLocalTime(&timeinfo)) {
    return;
  }

  char horaStr[10];
  char dataStr[20];

  strftime(
    horaStr,
    sizeof(horaStr),
    "%H:%M",
    &timeinfo
  );

  strftime(
    dataStr,
    sizeof(dataStr),
    "%d/%m/%Y",
    &timeinfo
  );

  // ==========================================
  // JSON
  // ==========================================
  String json = "{";

  json += "\"hora\":\"" +
          String(horaStr) + "\",";

  json += "\"data\":\"" +
          String(dataStr) + "\",";

  json += "\"porcentagem\":" +
          String(umidade) + ",";

  json += "\"key\":\"" +
          String(API_KEY) + "\"";

  json += "}";

  HTTPClient http;

  http.begin(API_BASE_URL);

  http.addHeader(
    "Content-Type",
    "application/json"
  );

  int httpCode =
  http.POST(json);

  Serial.println(
    "========== API =========="
  );

  Serial.print("HTTP CODE: ");
  Serial.println(httpCode);

  Serial.print("JSON: ");
  Serial.println(json);

  Serial.println(
    "========================="
  );

  http.end();
}

// ======================================================
// TASMOTA
// ======================================================
void ligarBombaTasmota() {

  if (WiFi.status() != WL_CONNECTED)
    return;

  HTTPClient http;

  http.begin(getTasmotaOn());

  http.GET();

  http.end();
}

void desligarBombaTasmota() {

  if (WiFi.status() != WL_CONNECTED)
    return;

  HTTPClient http;

  http.begin(getTasmotaOff());

  http.GET();

  http.end();
}

// ======================================================
// ROTAS WEB
// ======================================================
void handleRoot() {

  server.send(
    200,
    "text/html",
    gerarPagina()
  );
}

void handleData() {

  String json = "{";

  json += "\"umidade\":" +
          String(umidade) + ",";

  json += "\"bomba\":" +
          String(
            bombaLigada ?
            "true" :
            "false"
          ) + ",";

  json += "\"manual\":" +
          String(
            modoManual ?
            "true" :
            "false"
          );

  json += "}";

  server.send(
    200,
    "application/json",
    json
  );
}

void handleSetNivel() {

  if (server.hasArg("valor")) {

    nivelMinimo =
    server.arg("valor").toInt();
  }

  server.send(
    200,
    "text/plain",
    "OK"
  );
}

void handleManual() {

  modoManual = !modoManual;

  server.send(
    200,
    "text/plain",
    "OK"
  );
}

void handleToggle() {

  bombaLigada = !bombaLigada;

  if (bombaLigada) {
    ligarBombaTasmota();
  }
  else {
    desligarBombaTasmota();
  }

  server.send(
    200,
    "text/plain",
    "OK"
  );
}

// ======================================================
// SETUP
// ======================================================
void setup() {

  Serial.begin(115200);

  // ==========================================
  // WIFI
  // ==========================================
  conectarWiFiMulti();

  WiFi.setSleep(true);

  // ==========================================
  // HORARIO
  // ==========================================
  sincronizarHorario();

  // ==========================================
  // ROTAS
  // ==========================================
  server.on("/", handleRoot);

  server.on(
    "/data",
    handleData
  );

  server.on(
    "/setnivel",
    handleSetNivel
  );

  server.on(
    "/manual",
    handleManual
  );

  server.on(
    "/toggle",
    handleToggle
  );

  // ==========================================
  // OTA WEB
  // ==========================================
  server.on("/update", HTTP_GET, []() {

    server.send(
      200,
      "text/html",

      "<form method='POST' action='/update' enctype='multipart/form-data'>"
      "<input type='file' name='update'>"
      "<input type='submit' value='Atualizar'>"
      "</form>"
    );
  });

  server.on("/update", HTTP_POST, []() {

 if (
    !server.authenticate(
      OTA_USER,
      OTA_PASS
    )
  ) {

    return server.requestAuthentication();
  }

  server.send(
    200,
    "text/html",

    "<form method='POST' action='/update' enctype='multipart/form-data'>"
    "<input type='file' name='update'>"
    "<input type='submit' value='Atualizar'>"
    "</form>"
  );
});

server.on("/update", HTTP_POST, []() {

  if (
    !server.authenticate(
      OTA_USER,
      OTA_PASS
    )
  ) {

    return server.requestAuthentication();
  }

  server.send(
    200,
    "text/plain",
    Update.hasError() ?
    "Falha" :
    "Sucesso"
  );

  delay(1000);

  ESP.restart();

}, []() {

  HTTPUpload& upload =
  server.upload();

  if (
    upload.status ==
    UPLOAD_FILE_START
  ) {

    Update.begin(
      UPDATE_SIZE_UNKNOWN
    );
  }

  else if (
    upload.status ==
    UPLOAD_FILE_WRITE
  ) {

    Update.write(
      upload.buf,
      upload.currentSize
    );
  }

  else if (
    upload.status ==
    UPLOAD_FILE_END
  ) {

    Update.end(true);
  }
});

  // ==========================================
  // INICIA SERVIDOR
  // ==========================================
  server.begin();

  Serial.println(
    "Servidor iniciado"
  );
}


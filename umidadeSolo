#include <WiFi.h>
#include <WebServer.h>
#include <HTTPClient.h>

// ======================================================
// CONFIGURACAO DOS PINOS
// ======================================================
#define SENSOR_PIN 2

// ======================================================
// WIFI
// ======================================================
const char* ssid = "";
const char* password = "";

// ======================================================
// TASMOTA
// ======================================================
const char* tasmotaOn  = "http://192.168.15.109/cm?cmnd=Power%20On";
const char* tasmotaOff = "http://192.168.15.109/cm?cmnd=Power%20Off";

// ======================================================
// SERVIDOR WEB
// ======================================================
WebServer server(80);

// ======================================================
// VARIAVEIS GLOBAIS
// ======================================================
int umidade = 0;
int nivelMinimo = 30;

bool bombaLigada = false;
bool modoManual = false;

unsigned long ultimaLeitura = 0;
const unsigned long intervaloLeitura = 1000;

// ======================================================
// PAGINA WEB
// ======================================================
String gerarPagina() {

  String html = R"rawliteral(

<!DOCTYPE html>
<html>

<head>

<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

body{
  font-family: Arial;
  text-align:center;
  background:#f2f2f2;
}

.container{
  padding:20px;
  margin:auto;
  max-width:400px;
  background:white;
  border-radius:10px;
  box-shadow:0 0 10px #ccc;
}

